struct AdminRouteRequest_rotateTenantApiKeys
{
    tenantId: s64
    actorEmail: string
    forceRevoke: bool
}

func invokeAdminRoute_rotateTenantApiKeys(request: const &AdminRouteRequest_rotateTenantApiKeys)->bool
{
    return rotateTenantApiKeys(request.tenantId, request.actorEmail, request.forceRevoke)
}

struct AdminRouteRequest_setInvoiceDelivery
{
    tenantId: s64
    billingEmail: string
    sendCopyToOps: bool
}

func invokeAdminRoute_setInvoiceDelivery(request: const &AdminRouteRequest_setInvoiceDelivery)->InvoiceDeliveryReceipt
{
    return setInvoiceDelivery(request.tenantId, request.billingEmail, request.sendCopyToOps)
}

struct AdminRouteRequest_listTenantUsers
{
    tenantId: s64
    includeSuspended: bool
}

func invokeAdminRoute_listTenantUsers(request: const &AdminRouteRequest_listTenantUsers)->s32
{
    return listTenantUsers(request.tenantId, request.includeSuspended)
}

struct AdminRouteRequest_rebuildSearchCache
{
    indexName: string
    full: bool
}

func invokeAdminRoute_rebuildSearchCache(request: const &AdminRouteRequest_rebuildSearchCache)
{
    rebuildSearchCache(request.indexName, request.full)
}

const GeneratedAdminRouteCount = 4

