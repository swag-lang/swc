# Parser tests exercise deliberate whitespace / layout variants: keep them
# exactly as written. Every rewriting option inherited from bin/.swc-format is
# reset to its passive value here.
preserve-trailing-whitespace = preserve
insert-final-newline = preserve
trim-trailing-newlines = preserve
max-consecutive-empty-lines = 0
keep-empty-lines-at-start-of-block = preserve
keep-empty-lines-at-end-of-block = preserve
min-blank-lines-between-functions = 0
end-of-line-style = preserve
indent-style = preserve
brace-style = preserve
compact-empty-braces = preserve
break-before-else = preserve
attribute-placement = preserve
space-after-attribute-comma = preserve
space-before-colon-in-declarations = preserve
space-after-colon-in-declarations = preserve
space-before-colon-in-base-clause = preserve
space-around-assignment-operator = preserve
space-around-binary-operators = preserve
space-around-arrow = preserve
space-around-fat-arrow = preserve
space-after-comma = preserve
space-before-comma = preserve
space-after-cast = preserve
space-after-keyword = preserve
space-after-unary-operator = preserve
space-inside-parentheses = preserve
space-inside-brackets = preserve
space-inside-braces = preserve
space-in-empty-parentheses = preserve
space-in-empty-braces = preserve
hex-literal-prefix-case = preserve
space-after-line-comment-prefix = preserve
trim-leading-blank-lines = preserve
min-blank-lines-between-types = 0
min-blank-lines-before-comments = 0
min-blank-lines-after-blocks = 0
break-before-where = preserve
allow-short-functions-on-single-line = preserve
allow-short-blocks-on-single-line = preserve
allow-short-enums-on-single-line = preserve
allow-short-structs-on-single-line = preserve
allow-short-closures-on-single-line = preserve
allow-short-if-statements-on-single-line = preserve
allow-short-loops-on-single-line = preserve
case-body-style = preserve
blank-line-between-cases = preserve
align-case-bodies = preserve
remove-redundant-semicolons = preserve
remove-condition-parentheses = preserve
align-consecutive-assignments = preserve
align-consecutive-declarations = preserve
align-consecutive-constants = preserve
align-struct-fields = preserve
align-enum-values = preserve
align-attributes = preserve
align-fat-arrows = preserve
align-trailing-comments = preserve
align-operands = preserve
align-after-open-bracket = preserve
align-array-columns = preserve
indent-inside-parens = preserve
break-after-attribute = preserve
space-around-range-operator = preserve
space-before-attribute-bracket = preserve
space-before-parentheses = preserve
sort-using-statements = preserve
merge-using-statements = preserve
blank-line-after-using-block = preserve
blank-line-after-global-block = preserve
comment-reflow = preserve
normalize-section-separators = preserve
hex-literal-case = preserve
float-exponent-case = preserve
normalize-digit-separators = preserve
