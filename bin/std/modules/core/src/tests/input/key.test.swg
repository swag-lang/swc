#test
{
    @assert(Input.getKeyName(.Zero, .A) == "A")
    @assert(Input.getKeyName(.Alt, .A) == "Alt+A")
    @assert(Input.getKeyName(.Control, .A) == "Ctrl+A")
    @assert(Input.getKeyName(.Shift, .A) == "Shift+A")
    @assert(Input.getKeyName(.CtrlShift, .A) == "Ctrl+Shift+A")
    @assert(Input.getKeyName(.CtrlAlt, .A) == "Alt+Ctrl+A")
    @assert(Input.getKeyName(.Alt | .Shift, .A) == "Alt+Shift+A")

    @assert(Input.getKeyName(.Zero, .NumPad0) == "0")
    @assert(Input.getKeyName(.Zero, .NumPad1) == "1")
    @assert(Input.getKeyName(.Zero, .NumPad2) == "2")
    @assert(Input.getKeyName(.Zero, .NumPad3) == "3")
    @assert(Input.getKeyName(.Zero, .NumPad4) == "4")
    @assert(Input.getKeyName(.Zero, .NumPad5) == "5")
    @assert(Input.getKeyName(.Zero, .NumPad6) == "6")
    @assert(Input.getKeyName(.Zero, .NumPad7) == "7")
    @assert(Input.getKeyName(.Zero, .NumPad8) == "8")
    @assert(Input.getKeyName(.Zero, .NumPad9) == "9")
    @assert(Input.getKeyName(.Zero, .Add) == "+")
    @assert(Input.getKeyName(.Zero, .Subtract) == "-")
    @assert(Input.getKeyName(.Zero, .F10) == "F10")
}
