#global #if #command == Swag.CompilerCommand.Test
#global private

using Swag, Core

// Build the right-side properties panel the way the app does (quick styles pane on
// top, properties pane below) and return it, laid out.
func testSetupPropWnd(f: *HeadlessFixture)->*PropWnd
{
    f.gui.surfaceWnd.view = f.main

    with f.main.quickStyleBar = SplitterCtrl.create(f.main, {600, 0, 300, 650}, vertical: true)
    {
        .splitterFlags.add(.HideBars)
    }

    f.main.quickWnd = QuickWnd.create(f.main.quickStyleBar, f.main)
    f.main.propWnd  = PropWnd.create(f.main.quickStyleBar, f.main)
    discard f.main.quickStyleBar.addPane(f.main.quickWnd, title: true)
    discard f.main.quickStyleBar.addPane(f.main.propWnd, title: true)
    f.main.quickStyleBar.setPaneSize(0, 300)
    f.main.quickWnd.setDefault()
    return f.main.propWnd
}

func testFindItem(prop: *PropWnd, name: string)->#null *PropertiesItem
{
    for item in prop.grid.items
    {
        if item.typeValue.name == name do
            return item
    }

    return null
}

func testItemIndex(prop: *PropWnd, name: string)->u64
{
    for item, idx in prop.grid.items
    {
        if item.typeValue.name == name do
            return idx
    }

    @assert(false)
    return 0
}

// A selected text form generates the full grid: retargeted outline slider, joins combo
// without `JoinStyle.None`, category separators, and the compact x/y and w/h rows
// appended at the very end. Every row spans the panel width.
#test
{
    var f: HeadlessFixture
    f.setup()
    let prop = testSetupPropWnd(&f)

    let tf = testAddText(f.capture, 10, 20, 100, 50)
    f.capture.selection.add(0)
    prop.selectionHasChanged()
    f.gui.pump()

    // The border-size row is generated by the grid and retargeted for a text form
    let border = testFindItem(prop, #nameof(BaseForm.borderSize))
    @assert(border != null and border.sliderBox != null)
    @assert(border.sliderBox.label.name == "Outline")
    @assert(border.sliderBox.slider.min == MinTextBorderSize)
    @assert(border.sliderBox.slider.max == MaxTextBorderSize)

    // The joins row is a generated combo omitting JoinStyle.None: Round selects index 1
    let joins = testFindItem(prop, #nameof(BaseForm.joinStyle))
    @assert(joins != null and joins.comboBox != null)
    @assert(joins.comboBox.items.count == 4)
    @assert(tf.joinStyle == .Round)
    @assert(joins.comboBox.selectedIdx == 1)

    // Most specific first: the text form's own fields come before the shared BaseForm
    // block, even though the language declares 'using base' first
    @assert(testItemIndex(prop, #nameof(FormText.fontName)) < testItemIndex(prop, #nameof(BaseForm.borderSize)))
    @assert(testItemIndex(prop, #nameof(FormText.fontSize)) < testItemIndex(prop, #nameof(BaseForm.borderSize)))
    @assert(testItemIndex(prop, #nameof(BaseForm.borderSize)) < testItemIndex(prop, "Effects"))

    // Group separator above the scale/rotate/opacity/shadow block
    @assert(testFindItem(prop, "Effects") != null)

    // The x/y and w/h rows close the grid, below their own separator
    let n = prop.grid.items.count
    @assert(n >= 3)
    @assert(prop.grid.items[n - 1].typeValue.name == "size")
    @assert(prop.grid.items[n - 2].typeValue.name == "position")
    @assert(prop.grid.items[n - 3].typeValue.name == "Position")

    // Rows span the whole panel width (they used to be clamped to sizeEditValue)
    @assert(border.line.position.width > 250)
    @assert(border.line.position.width >= prop.grid.position.width - 24)

    f.shutdown()
}

// A selected step form hides the whole border/joins block and gets no position/size
// rows. The effects separator stays: its group (opacity/shadow) is still visible, and
// a separator shows exactly when its group has at least one visible row.
#test
{
    var f: HeadlessFixture
    f.setup()
    let prop = testSetupPropWnd(&f)

    discard testAddStep(f.capture, 10, 20, 100, 50)
    f.capture.selection.add(0)
    prop.selectionHasChanged()
    f.gui.pump()

    let border = testFindItem(prop, #nameof(BaseForm.borderSize))
    @assert(border != null and !border.line.isVisible())
    let joins = testFindItem(prop, #nameof(BaseForm.joinStyle))
    @assert(joins != null and !joins.line.isVisible())
    let effects = testFindItem(prop, "Effects")
    @assert(effects != null and effects.line.isVisible())

    @assert(testFindItem(prop, "position") == null)
    @assert(testFindItem(prop, "size") == null)

    f.shutdown()
}

// A pixel-selection shape hides the whole style content, separators included (no
// visible row is left in their groups).
#test
{
    var f: HeadlessFixture
    f.setup()
    let prop = testSetupPropWnd(&f)

    discard testAddShape(f.capture, 10, 20, 100, 50, subKind: .PixSel)
    f.capture.selection.add(0)
    prop.selectionHasChanged()
    f.gui.pump()

    let border = testFindItem(prop, #nameof(BaseForm.borderSize))
    @assert(border != null and !border.line.isVisible())
    let round = testFindItem(prop, #nameof(FormShape.roundSize))
    @assert(round != null and !round.line.isVisible())
    let effects = testFindItem(prop, "Effects")
    @assert(effects != null and !effects.line.isVisible())

    f.shutdown()
}
