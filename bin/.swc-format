# ============================================================================
# Swag code formatter configuration
# ============================================================================
# This file configures the formatter run by `swc format` on `.swg` sources.
# The values below match the style of the code base under `bin/`: running
# `format.bat` should be (close to) a no-op on conformant sources.
# Enum options list their accepted values on a `# Possible values:` line.
# Options set to `preserve` keep the source exactly as written.

# ----------------------------------------------------------------------------
# File-level whitespace
# ----------------------------------------------------------------------------

# Preserve UTF-8 BOM markers already present in the file.
preserve-bom = true

# Keep trailing whitespace on existing lines unchanged.
preserve-trailing-whitespace = false

# Ensure the file ends with a single newline.
insert-final-newline = true

# Collapse multiple trailing newlines to one.
trim-trailing-newlines = true

# Maximum blank lines allowed in a row (0 disables the limit).
max-consecutive-empty-lines = 1

# Keep blank lines at the start of a `{ ... }` block.
keep-empty-lines-at-start-of-block = false

# Keep blank lines at the end of a `{ ... }` block.
keep-empty-lines-at-end-of-block = false

# Minimum blank lines between function declarations (0 keeps the source as written).
min-blank-lines-between-functions = 0

# ----------------------------------------------------------------------------
# End-of-line
# ----------------------------------------------------------------------------

# Line-ending style written back to the file.
# Possible values: preserve, lf, crlf
end-of-line-style = crlf

# ----------------------------------------------------------------------------
# Indentation
# ----------------------------------------------------------------------------

# Use spaces, tabs, or keep the existing style. Any value other than
# `preserve` re-indents statements to their canonical block depth (wrapped
# continuation lines keep their relative indentation).
# Possible values: preserve, spaces, tabs
indent-style = spaces

# Indent width used when formatting with spaces.
indent-width = 4

# Visual width assumed for a tab character.
tab-width = 4

# Extra indent for wrapped continuations.
continuation-indent-width = 4

# Indent content nested inside a `namespace` block.
indent-namespace-body = true

# Indent content nested inside an `impl` block.
indent-impl-body = true

# Indent content nested inside a `struct` block.
indent-struct-body = true

# Indent content nested inside an `enum` block.
indent-enum-body = true

# Indent `case` labels one level inside the enclosing `switch`.
indent-case-labels = false

# Indent the body of a `case` relative to its label.
indent-case-blocks = true

# Attributes adopt the indentation of the declaration they apply to.
indent-attributes = true

# Indent wrapped arguments relative to the opening parenthesis.
indent-inside-parens = preserve

# ----------------------------------------------------------------------------
# Column limit & wrapping
# ----------------------------------------------------------------------------

# Soft column limit used when wrapping (0 disables wrapping).
column-limit = 0

# Where to break long expressions relative to their binary operator.
# Possible values: preserve, before, after, none
break-before-binary-operators = preserve

# Break long `cond ? a : b` expressions before `?` and `:`.
break-before-ternary-operators = preserve

# Insert a line break before `->` in function signatures that don't fit.
break-after-return-type = preserve

# Place trailing `do` on a new line when its statement is wrapped.
break-before-do = preserve

# Place `else` on its own line (Stroustrup / Allman style).
break-before-else = true

# How to lay out arguments across lines in calls.
# Possible values: preserve, pack, one-per-line
bin-pack-arguments = preserve

# How to lay out parameters across lines in declarations.
# Possible values: preserve, pack, one-per-line
bin-pack-parameters = preserve

# ----------------------------------------------------------------------------
# Braces & short bodies
# ----------------------------------------------------------------------------

# Opening brace placement policy.
# Possible values: preserve, attach, allman, stroustrup
brace-style = allman

# Keep `{}` on the opening line.
compact-empty-braces = true

# When to keep function bodies on a single line.
# Possible values: preserve, never, empty, inline, always
allow-short-functions-on-single-line = preserve

# When to keep generic `{ ... }` blocks on a single line.
# Possible values: preserve, never, empty, inline, always
allow-short-blocks-on-single-line = preserve

# When to keep `enum` bodies on a single line.
# Possible values: preserve, never, empty, inline, always
allow-short-enums-on-single-line = preserve

# When to keep `struct` bodies on a single line.
# Possible values: preserve, never, empty, inline, always
allow-short-structs-on-single-line = preserve

# Allow `if x do ...` / `if x { ... }` on one line.
allow-short-if-statements-on-single-line = preserve

# Allow `while`/`for` bodies on one line.
allow-short-loops-on-single-line = preserve

# Allow single-statement `case` arms to stay on one line.
allow-short-case-on-single-line = preserve

# ----------------------------------------------------------------------------
# Alignment
# ----------------------------------------------------------------------------
# The code base aligns by hand in many hot spots; the formatter keeps those
# as written instead of enforcing machine grouping.

# Align `=` signs in adjacent assignments.
# Possible values: preserve, none, consecutive, across-blanks, all
align-consecutive-assignments = preserve

# Align names/types of adjacent `let`/`var` declarations.
# Possible values: preserve, none, consecutive, across-blanks, all
align-consecutive-declarations = preserve

# Align values of adjacent `const` declarations.
# Possible values: preserve, none, consecutive, across-blanks, all
align-consecutive-constants = preserve

# Align `:` and types of adjacent struct fields.
# Possible values: preserve, none, consecutive, across-blanks, all
align-struct-fields = preserve

# Align `=` on adjacent enum value definitions.
# Possible values: preserve, none, consecutive, across-blanks, all
align-enum-values = preserve

# Align adjacent `#[...]` attributes.
# Possible values: preserve, none, consecutive, across-blanks, all
align-attributes = preserve

# Align `//` trailing comments into a shared column.
align-trailing-comments = true

# Minimum number of spaces between code and a trailing `//` comment.
trailing-comment-min-spaces = 5

# Max column for trailing comments (0 disables the cap).
trailing-comment-max-column = 0

# Align operands of wrapped binary expressions.
align-operands = preserve

# Align wrapped arguments with the opening `(` / `[`.
align-after-open-bracket = preserve

# ----------------------------------------------------------------------------
# Spacing
# ----------------------------------------------------------------------------
# A `true` spacing option inserts a missing blank but keeps wider runs (they
# are treated as manual alignment); a `false` option removes the blanks.

# Insert a space before `:` in declarations like `a : u8`.
space-before-colon-in-declarations = false

# Insert a space after `:` in declarations like `a: u8`.
space-after-colon-in-declarations = true

# Insert a space before `:` in `enum E: u32` / `using base: Foo`.
space-before-colon-in-base-clause = false

# Insert spaces around `=` in assignments.
space-around-assignment-operator = true

# Insert spaces around binary operators (`+`, `*`, `&`, ...).
space-around-binary-operators = true

# Insert spaces around `->` in function signatures.
space-around-arrow = false

# Insert spaces around `=>` in short function bodies.
space-around-fat-arrow = true

# Insert spaces around `..` range operators.
space-around-range-operator = preserve

# Insert a space after `,`.
space-after-comma = true

# Insert a space before `,`.
space-before-comma = false

# Insert a space after a `cast(...)` expression.
space-after-cast = true

# Insert a space after control keywords such as `if`, `while`, `for`.
space-after-keyword = true

# Insert a space after unary operators like `-` or `!`.
space-after-unary-operator = false

# Insert spaces just inside `(` and `)`.
space-inside-parentheses = false

# Insert spaces just inside `[` and `]`.
space-inside-brackets = false

# Insert spaces just inside `{` and `}` in initializer lists.
space-inside-braces = false

# Insert a space inside `()` when empty.
space-in-empty-parentheses = false

# Insert a space inside `{}` when empty.
space-in-empty-braces = false

# Insert a space before `#[` when an attribute is placed inline.
space-before-attribute-bracket = preserve

# When to insert a space between a control keyword and a parenthesized
# condition. Swag forbids blanks before call / declaration parentheses, so
# this option only affects control statements.
# Possible values: preserve, never, always, control-statements, functions, non-empty
space-before-parentheses = preserve

# ----------------------------------------------------------------------------
# Attributes
# ----------------------------------------------------------------------------

# How to place `#[Attr]` annotations relative to their declaration.
# Possible values: preserve, own-line, grouped, inline
attribute-placement = own-line

# Force a line break between an attribute and the declaration it applies to.
break-after-attribute = preserve

# Insert a space after `,` inside `#[A, B, C]`.
space-after-attribute-comma = true

# Sort attribute argument lists alphabetically.
sort-attribute-arguments = false

# ----------------------------------------------------------------------------
# Comments
# ----------------------------------------------------------------------------

# How aggressively to rewrite comments to fit the column limit.
# Possible values: preserve, normalize, reflow
comment-reflow = preserve

# Rewrite `// ####...` banners so they share a common width.
normalize-section-separators = preserve

# Target column count for normalized `// ####...` banners.
section-separator-width = 57

# Insert a space after `//` when rewriting line comments.
space-after-line-comment-prefix = true

# ----------------------------------------------------------------------------
# Imports / using
# ----------------------------------------------------------------------------

# Sort order for `using` statements at the top of a file.
# Possible values: preserve, ascending, ascending-ci
sort-using-statements = preserve

# Collapse adjacent `using` statements onto a single line when possible.
merge-using-statements = preserve

# Guarantee a blank line after the initial `using` block.
blank-line-after-using-block = preserve

# ----------------------------------------------------------------------------
# Numeric literals
# ----------------------------------------------------------------------------

# Case of hexadecimal digits (`0xABCD` vs `0xabcd`).
# Possible values: preserve, upper, lower
hex-literal-case = preserve

# Case of the `0x` / `0X` hexadecimal prefix (also applies to `0b` / `0B`).
# Possible values: preserve, upper, lower
hex-literal-prefix-case = lower

# Case of the floating-point exponent letter (`1e10` vs `1E10`).
# Possible values: preserve, upper, lower
float-exponent-case = preserve

# Rewrite long numeric literals using `_` digit separators.
normalize-digit-separators = preserve

# Digit grouping size used for `0x` and `0b` literals when normalizing separators.
hex-digit-separator-group-size = 4

# Digit grouping size used for decimal and float literals when normalizing separators.
decimal-digit-separator-group-size = 3

# ----------------------------------------------------------------------------
# Region / disable pragmas
# ----------------------------------------------------------------------------

# Comment marker that disables formatting until the matching `format-on-comment`.
format-off-comment = "swc-format off"

# Comment marker that re-enables formatting after `format-off-comment`.
format-on-comment = "swc-format on"
