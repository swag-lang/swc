func findGeneratedAdminRoute(method: string, path: string)->s32
{
    if method == "POST" and path == "/tenants/:tenantId/rotate-api-keys" do
        return 0
    if method == "POST" and path == "/billing/invoice-delivery" do
        return 1
    if method == "GET" and path == "/tenants/:tenantId/users" do
        return 2
    if method == "POST" and path == "/internal/search/rebuild-cache" do
        return 3
    return -1
}

func countCriticalAdminRoutes()->s32
{
    var count: s32
    count += 1
    count += 1
    return count
}
