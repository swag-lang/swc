SWC_DIAG_DEF(lex_err_not_utf8, Error, "source file is not valid UTF-8; [help] save the file using UTF-8 encoding")
SWC_DIAG_DEF(lex_err_unclosed_comment, Error, "unclosed block comment; [help] add '*/' to close it before the end of the file")
SWC_DIAG_DEF(lex_err_string_eol, Error, "newline inside a single-line string literal; [help] close the string with '\"' on the same line, or use a multi-line string '\"\"\" ... \"\"\"'")
SWC_DIAG_DEF(lex_err_unclosed_string, Error, "unclosed string literal; [help] add the closing quote")
SWC_DIAG_DEF(lex_err_consecutive_num_sep, Error, "consecutive '_' separators in numeric literal; [help] use at most one '_' between digits")
SWC_DIAG_DEF(lex_err_leading_num_sep, Error, "leading '_' before the fractional or exponent digits; [help] place '_' only between digits")
SWC_DIAG_DEF(lex_err_trailing_num_sep, Error, "trailing '_' in numeric literal; [help] remove the trailing '_', it must sit between digits")
SWC_DIAG_DEF(lex_err_missing_hex_digit, Error, "hexadecimal literal '0x' has no digits; [help] add at least one digit in 0-9, a-f, or A-F")
SWC_DIAG_DEF(lex_err_missing_bin_digit, Error, "binary literal '0b' has no digits; [help] add at least one binary digit (0 or 1)")
SWC_DIAG_DEF(lex_err_missing_exponent, Error, "exponent has no digits; [help] write the exponent as 'e' or 'E' followed by an optional sign and one or more digits, e.g. '1e10' or '2.5E-3'")
SWC_DIAG_DEF(lex_err_invalid_bin_digit, Error, "invalid binary digit '{tok}'; [help] binary literals may only contain '0' and '1'")
SWC_DIAG_DEF(lex_err_invalid_escape, Error, "invalid escape sequence '{tok}'; [help] did you mean '{value}'?")
SWC_DIAG_DEF(lex_err_invalid_escape, Error, "invalid escape sequence '{tok}'; [help] after a backslash, use one of: 0 a b f n r t v x u U or the literal characters backslash, single-quote, or double-quote")
SWC_DIAG_DEF(lex_err_empty_char, Error, "empty character literal; [help] write exactly one character or escape between the quotes, e.g. 'a' or '\\n'")
SWC_DIAG_DEF(lex_err_unclosed_char, Error, "unclosed character literal; [help] add the closing quote")
SWC_DIAG_DEF(lex_err_invalid_hex_digit, Error, "invalid hexadecimal digit '{tok}'; [help] hex digits must be in 0-9, a-f, or A-F")
SWC_DIAG_DEF(lex_err_incomplete_hex_escape, Error, "incomplete hexadecimal escape '{tok}'; [help] '\\x' takes 2 digits, '\\u' takes 4, '\\U' takes 8 (expected {value})")
SWC_DIAG_DEF(lex_err_empty_hex_escape, Error, "empty hexadecimal escape '{tok}'; [help] add the expected hex digits after '\\x', '\\u', or '\\U'")
SWC_DIAG_DEF(lex_err_too_many_char_char, Error, "character literal contains {value} characters; [help] use a string literal \"...\" for multiple characters")
SWC_DIAG_DEF(lex_err_too_many_char_char, Error, "character literal contains more than one character; [help] use a string literal \"...\" for multiple characters")
SWC_DIAG_DEF(lex_err_invalid_number_suffix, Error, "unexpected suffix '{tok}' on numeric literal; [help] add a space between the number and the following identifier")
SWC_DIAG_DEF(lex_err_invalid_char, Error, "invalid character U+{value} in source code; [help] only ASCII characters are allowed outside comments, strings, and character literals")
SWC_DIAG_DEF(lex_err_reserved_identifier, Error, "identifier '{tok}' is reserved; [help] names starting with '__' are reserved for compiler and runtime internals")
