        }
        case 3: return {
            handler: "rebuildSearchCache",
            method: "POST",
            path: "/internal/search/rebuild-cache",
            permission: "ops.write",
            auditCode: "search.cache.rebuild",
            pathParamCount: 0,
            paramCount: 2,
            critical: true,
            returnsValue: false,
        }
    }

    return {
        handler: "",
